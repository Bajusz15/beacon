# Beacon Environment Configuration
# Generated by Beacon Configuration Wizard
# 
# This is an example .env file generated by: beacon setup-wizard
# 
# Copy this file to .env and fill in your actual values:
#   cp beacon.wizard.example.env .env
#   nano .env
#
# The wizard creates this file with placeholders that you need to fill in
# based on which plugins and services you enabled.

# Email SMTP
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=beacon@example.com
SMTP_TO=admin@example.com

# BeaconWatch
# Get your token from: https://beaconinfra.dev/
BEACONINFRA_TOKEN=your-beaconinfra-token
